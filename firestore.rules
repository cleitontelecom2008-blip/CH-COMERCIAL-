rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    // Admin: defina o UID do seu usuário admin abaixo
    function isAdmin() { return isAuth() && request.auth.uid == "SEU_UID_ADMIN"; }

    // ── Dados PDV por empresa ──────────────────────────────────
    // saas_dados/{uid} → apenas a própria empresa pode ler/escrever
    match /saas_dados/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // ── Registro de empresa ────────────────────────────────────
    // empresas/{uid} → owner lê/atualiza seus próprios dados
    //                  admin lê/escreve qualquer empresa
    match /empresas/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
      // Permite criação apenas para o próprio usuário
      allow create: if isOwner(uid);
    }

    // ── Bloqueia todo o resto ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

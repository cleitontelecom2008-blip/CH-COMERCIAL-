rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }
    function isOwner(docUid) { return isAuth() && uid() == docUid; }

    /// Admin via coleção (não hardcoded)
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admins/$(uid()));
    }

    /// Obtém o empresaId do usuário autenticado via coleção usuarios
    function userEmpresaId() {
      return get(/databases/$(database)/documents/usuarios/$(uid())).data.empresaId;
    }

    /// Verifica se o usuário pertence à empresa do documento
    function isEmpresaMember(empresaId) {
      return isAuth() && userEmpresaId() == empresaId;
    }

    /// Campos reservados — só admin pode alterar
    function tocarCamposReservados() {
      let reservados = ['plano','planoReal','planoExpira','status','criadoEm','dono','limites'];
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(reservados);
    }

    // ── Coleção: admins ────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // ── Coleção: empresas ──────────────────────────────────────────────────
    // Estrutura: empresas/{empresaId} → { nome, plano, status, criadoEm, dono, ... }
    //
    // - Admin: acesso total
    // - Membro da empresa: lê e atualiza campos não-reservados (nome, vendasMes, mesAtual)
    // - Criação: qualquer autenticado (ocorre apenas no cadastro, controlado por saas-auth.js)
    // - Exclusão: somente admin
    match /empresas/{empresaId} {
      allow read:   if isEmpresaMember(empresaId) || isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin()
                    || (isEmpresaMember(empresaId) && !tocarCamposReservados());
      allow delete: if isAdmin();
    }

    // ── Coleção: usuarios ──────────────────────────────────────────────────
    // Estrutura: usuarios/{uid} → { empresaId, nome, email, cargo, criadoEm, ultimoAcesso }
    //
    // - Admin: acesso total
    // - Próprio usuário: lê e atualiza o próprio documento
    //   (não pode alterar empresaId ou cargo — campos reservados)
    match /usuarios/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
                    || (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys().hasAny(['empresaId','cargo','criadoEm']));
      allow delete: if isAdmin();
    }

    // ── Coleção: saas_dados ────────────────────────────────────────────────
    // Estrutura: saas_dados/{empresaId} → dados PDV isolados por empresa
    //
    // - Admin: acesso total
    // - Membro da empresa: lê e escreve nos próprios dados
    // - Exclusão: somente admin
    match /saas_dados/{empresaId} {
      allow read:   if isEmpresaMember(empresaId) || isAdmin();
      allow create: if isEmpresaMember(empresaId) || isAdmin();
      allow update: if isEmpresaMember(empresaId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Bloqueia todo o resto ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
